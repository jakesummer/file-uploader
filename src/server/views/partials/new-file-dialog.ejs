<wa-dialog label="Upload New File" id="new-file-dialog">
  <form action="/item/create/file" method="post" id="new-file-form">
    <input type="file" name="file" required />
  </form>
  <wa-button
    appearance="outlined"
    variant="danger"
    data-dialog="close"
    slot="footer"
    >Close</wa-button
  >
  <wa-button type="submit" form="new-file-form" variant="brand" slot="footer"
    >Upload</wa-button
  >
</wa-dialog>
