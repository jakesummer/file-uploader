<%# New File %>
<wa-dialog label="Upload New File" id="new-file-dialog" light-dismiss>
  <form
    action="/item/create/file/<%= folderId %>"
    method="post"
    id="new-file-form"
    enctype="multipart/form-data"
  >
    <input type="file" name="file" required />
  </form>
  <wa-button
    appearance="outlined"
    variant="danger"
    data-dialog="close"
    slot="footer"
    >Close</wa-button
  >
  <wa-button type="submit" form="new-file-form" variant="brand" slot="footer"
    >Upload</wa-button
  >
</wa-dialog>

<%# New Folder %>
<wa-dialog label="Create New Folder" id="new-folder-dialog" light-dismiss>
  <form
    action="/item/create/folder/<%= folderId %>"
    method="post"
    id="new-folder-form"
  >
    <wa-input label="Name" name="name" required></wa-input>
  </form>
  <wa-button
    appearance="outlined"
    variant="danger"
    data-dialog="close"
    slot="footer"
    >Close</wa-button
  >
  <wa-button type="submit" form="new-folder-form" variant="brand" slot="footer"
    >Create</wa-button
  >
</wa-dialog>

<%# Delete Folder %>
<wa-dialog label="Delete Folder" id="delete-folder-dialog" light-dismiss>
  <form
    action="/item/delete/<%= folderId %>"
    method="post"
    id="delete-folder-form"
  >
    <p>Are you sure you want to delete this file and all of its contents?</p>
  </form>
  <wa-button
    appearance="outlined"
    variant="danger"
    data-dialog="close"
    slot="footer"
    >Cancel</wa-button
  >
  <wa-button
    type="submit"
    form="delete-folder-form"
    variant="brand"
    slot="footer"
    >Delete</wa-button
  >
</wa-dialog>

<%# File Info %>
<wa-dialog label="File Information" id="file-dialog" light-dismiss>
  <div>
    <p><strong>Name:</strong> <span id="dialog-file-name"></span></p>
    <p><strong>Size:</strong> <span id="dialog-file-size"></span></p>
    <p><strong>Created:</strong> <span id="dialog-file-created"></span></p>
  </div>
  <wa-button
    appearance="outlined"
    variant="danger"
    data-dialog="close"
    slot="footer"
    >Close</wa-button
  >
  <wa-button variant="brand" href="#" slot="footer" id="dialog-download-btn">
    <wa-icon name="download"></wa-icon>
    Download
  </wa-button>
</wa-dialog>
