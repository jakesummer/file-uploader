<% function buildTree(folders) { %>
  <% folders.forEach(folder => { %>
    <% const selected = String(folderId) === String(folder.id); %>
    <% const expanded = expandedFolderIds.has(String(folder.id))%>

    <wa-tree-item 
      <%= selected ? "selected" : "" %>
      class="<%= expanded ? "expanded" : "" %>"
    >
      <a href="/dashboard/<%= folder.id %>"><%= folder.name %></a>
      <% if (folder.children && folder.children.length > 0) { %>
        <% buildTree(folder.children) %>
      <% } %>
    </wa-tree-item>
  <% }) %>
<% } %>

<wa-tree>
  <% const rootSelected = folderId === undefined; %>

  <wa-tree-item expanded <%= rootSelected ? "selected" : "" %>>
    <a href="/dashboard"><%= tree.name %></a>
    <% buildTree(tree.children) %>
  </wa-tree-item>
</wa-tree>
