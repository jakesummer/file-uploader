<wa-button appearance="outlined" href="/dashboard/<%= item.id %>" class="item">
  <span class="item-grid">
    <span class="item-col-name">
      <wa-icon name="folder"></wa-icon>
      <p><%= item.name %></p>
    </span>
    <span class="item-col"><%= item.size || "--" %></span>
    <span class="item-col"><%= helpers.formatDate(item.createdAt) %></span>
  </span>
</wa-button>
